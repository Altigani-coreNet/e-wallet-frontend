# Copy to `.env` and set values. Restart `npm run dev` after changing `VITE_*`.

# Public site origin (no trailing slash). Used as default when other VITE_* URLs are omitted.
# VITE_PUBLIC_BASE_URL=https://fastpay.sd

# Payment SPA origin (Google OAuth redirect after sign-in: `{this}/login?google_oauth_code=...` is built on SoftPos from FRONTEND / MERCHANT_APP_URL).
# VITE_PUBLIC_FRONTEND_URL=https://fastpay.sd

# Auth (Passport) — merchant password login, profile, branches, etc.
# Production:
# VITE_AUTH_SERVICE_URL=https://fastpay.sd/api/coreservice
# Local (same host as SoftPos if one Laravel serves both):
VITE_AUTH_SERVICE_URL=http://localhost:8000

# SoftPos API — Google OAuth redirect + exchange, dashboards, payment links, etc.
# Must match Google Cloud "Authorized redirect URI" host: `{VITE_SOFTPOS_API_URL}/oauth/google/callback`
# Production:
# VITE_SOFTPOS_API_URL=https://fastpay.sd/api/softpos
VITE_SOFTPOS_API_URL=http://localhost:8000

# POS (Sales) API
VITE_POS_API_URL=http://localhost:8002

# PayTabs Node proxy (optional override)
# VITE_PAYTABS_API_URL=https://fastpay.sd/api/paytabs

# Reverb / Stripe / etc. — add as needed for your deployment
