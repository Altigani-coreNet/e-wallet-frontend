# Copy to cypress/.env.development for local overrides (gitignored via *.local pattern)
# Used by: node cypress/scripts/run.mjs development ...

# CYPRESS_apiUrl=http://localhost:8000
# Preferred dial code for country/city lookup (real GET /api/v1/countries APIs)
# CYPRESS_defaultCountryCode=249
# CYPRESS_apiRequestDelayMs=0
# CYPRESS_walletTransferFee=2
# CYPRESS_logAllApiCalls=true
# CYPRESS_adminEmail=admin@example.com
# CYPRESS_adminPassword=secret
